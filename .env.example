# Copy this file to .env and fill in your real Supabase values, then restart
# the dev server (npm run dev). Without this file the app runs but Supabase
# auth/data features won't work (you'll see errors in the browser console).
#
# Find these in your Supabase project: Project Settings > API
# Project ref for this repo is "vvsahuijmytvjevficpy" (see supabase/config.toml),
# so your URL is almost certainly:
VITE_SUPABASE_URL=https://vvsahuijmytvjevficpy.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key-here
